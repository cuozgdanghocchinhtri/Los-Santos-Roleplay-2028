+stock bool:CarControls_GetNearbyVehicle(playerid, &vehicleid)
+{
+    if (IsPlayerInAnyVehicle(playerid))
+    {
+        vehicleid = GetPlayerVehicleID(playerid);
+        if (vehicleid != INVALID_VEHICLE_ID && IsValidVehicle(vehicleid))
+        {
+            return true;
+        }
+    }
+
+    new Float:px, Float:py, Float:pz;
+    GetPlayerPos(playerid, px, py, pz);
+
+    new
+        foundVehicle = INVALID_VEHICLE_ID,
+        Float:bestDistance = CAR_CONTROL_NEAR_RADIUS + 0.001;
+
+    for (new id = 1; id < MAX_VEHICLES; id++)
+    {
+        if (!IsValidVehicle(id))
+        {
+            continue;
+        }
+
+        new Float:x, Float:y, Float:z;
+        GetVehiclePos(id, x, y, z);
+
+        new Float:distance = floatsqroot(
+            ((px - x) * (px - x)) +
+            ((py - y) * (py - y)) +
+            ((pz - z) * (pz - z))
+        );
+
+        if (distance <= CAR_CONTROL_NEAR_RADIUS && distance < bestDistance)
+        {
+            foundVehicle = id;
+            bestDistance = distance;
+        }
+    }
+
+    if (foundVehicle == INVALID_VEHICLE_ID)
+    {
+        SendClientMessage(
+            playerid,
+            COLOR_WHITE,
+            "{BFC0C2}Khong co phuong tien nao o gan ban. Hay dung trong pham vi {7A2929}5 met{BFC0C2} va thu lai."
+        );
+        return false;
+    }
+
+    vehicleid = foundVehicle;
     return true;
 }
 
