+stock CarControls_ShowStats(playerid)
+{
+    new vehicleid;
+    if (!CarControls_GetNearbyVehicle(playerid, vehicleid))
+    {
+        return 0;
+    }
+
+    new engine, lights, alarm, doors, bonnet, boot, objective;
+    CarControls_GetParams(
+        vehicleid,
+        engine,
+        lights,
+        alarm,
+        doors,
+        bonnet,
+        boot,
+        objective
+    );
+
+    new modelName[32], message[144];
+    new const modelID = GetVehicleModel(vehicleid);
+
+    if (modelID >= 400 && modelID <= 611)
+    {
+        Model_GetName(modelID, modelName);
+    }
+    else
+    {
+        format(modelName, sizeof(modelName), "Unknown");
+    }
+
+    format(
+        message,
+        sizeof(message),
+        "{BFC0C2}Phuong tien: {264A73}%s {BFC0C2}(ID %d / Model %d).",
+        modelName,
+        vehicleid,
+        modelID
+    );
+    SendClientMessage(playerid, COLOR_WHITE, message);
+
+    format(
+        message,
+        sizeof(message),
+        "{BFC0C2}Dong co: {264A73}%s {BFC0C2}| Den: {264A73}%s {BFC0C2}| Khoa: {264A73}%s",
+        engine == VEHICLE_PARAMS_ON ? "BAT" : "TAT",
+        lights == VEHICLE_PARAMS_ON ? "BAT" : "TAT",
+        doors == VEHICLE_PARAMS_ON ? "KHOA" : "MO"
+    );
+    SendClientMessage(playerid, COLOR_WHITE, message);
+
+    format(
+        message,
+        sizeof(message),
+        "{BFC0C2}Capo: {264A73}%s {BFC0C2}| Cop sau: {264A73}%s",
+        bonnet == VEHICLE_PARAMS_ON ? "MO" : "DONG",
+        boot == VEHICLE_PARAMS_ON ? "MO" : "DONG"
+    );
+    SendClientMessage(playerid, COLOR_WHITE, message);
+    return 1;
+}
