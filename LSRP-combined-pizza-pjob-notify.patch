+stock Pizza_FindFreeVehicleSpawn()
+{
+    for (new spawn = 0; spawn < sizeof(g_PizzaVehicleSpawns); spawn++)
+    {
+        new bool:occupied = false;
+
+        for (new vehicleid = 1; vehicleid < MAX_VEHICLES; vehicleid++)
