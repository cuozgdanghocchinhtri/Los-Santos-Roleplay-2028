diff --git a/database/migrations/007_character_current_job.sql b/database/migrations/007_character_current_job.sql
new file mode 100644
--- /dev/null
+++ b/database/migrations/007_character_current_job.sql
@@ -0,0 +1,18 @@
+-- LS:RP migration 007
+-- Current civilian job belongs directly to each character.
+
+USE `lsrp`;
+
+ALTER TABLE `player_characters`
+    ADD COLUMN IF NOT EXISTS `job`
+        TINYINT UNSIGNED NOT NULL DEFAULT 0
+        AFTER `level`,
+    ADD COLUMN IF NOT EXISTS `job_hired_at`
+        DATETIME NULL DEFAULT NULL
+        AFTER `job`,
+    ADD COLUMN IF NOT EXISTS `job_salary`
+        INT UNSIGNED NOT NULL DEFAULT 0
+        AFTER `job_hired_at`,
+    ADD COLUMN IF NOT EXISTS `job_allowance`
+        INT UNSIGNED NOT NULL DEFAULT 0
+        AFTER `job_salary`;
