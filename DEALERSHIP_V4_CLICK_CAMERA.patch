+// Hủy camera timer cũ để không có nhiều cinematic chạy chồng lên nhau.
+stock Dealership_StopCameraSweep(playerid)
+{
+    if (g_DealershipCameraTimer[playerid])
+    {
+        KillTimer(g_DealershipCameraTimer[playerid]);
+        g_DealershipCameraTimer[playerid] = 0;
+    }
+
+    g_DealershipCameraStage[playerid] = 0;
+    return 1;
+}
+
+// Lia camera quanh preview vehicle theo hai nhịp.
+// Nhịp 1 đi từ góc showroom hiện tại sang góc 3/4 đối diện.
+// Nhịp 2 tự động quay về camera mặc định.
+stock Dealership_StartCameraSweep(playerid)
+{
+    if (!g_DealershipActive[playerid])
+    {
+        return 0;
+    }
+
+    Dealership_StopCameraSweep(playerid);
+
+    g_DealershipCameraStage[playerid] = 1;
+
+    // Lia camera sang phía đối diện của vehicle.
+    InterpolateCameraPos(
+        playerid,
+        DEALERSHIP_CAMERA_X,
+        DEALERSHIP_CAMERA_Y,
+        DEALERSHIP_CAMERA_Z,
+        2127.20,
+        -1155.10,
+        26.70,
+        850,
+        CAMERA_MOVE
+    );
+
+    // Giữ camera luôn tập trung vào vehicle trong lúc lia.
+    InterpolateCameraLookAt(
+        playerid,
+        DEALERSHIP_LOOK_X,
+        DEALERSHIP_LOOK_Y,
+        DEALERSHIP_LOOK_Z,
+        DEALERSHIP_LOOK_X,
+        DEALERSHIP_LOOK_Y,
+        DEALERSHIP_LOOK_Z,
+        850,
+        CAMERA_MOVE
+    );
+
+    g_DealershipCameraTimer[playerid] =
+        SetTimerEx("Dealership_CameraSweepStage", 900, false, "d", playerid);
+
+    return 1;
+}
+
+// Chạy stage thứ hai của cinematic camera sweep.
+public Dealership_CameraSweepStage(playerid)
+{
+    g_DealershipCameraTimer[playerid] = 0;
+
+    if (!IsPlayerConnected(playerid) ||
+        !g_DealershipActive[playerid])
+    {
+        return 1;
+    }
+
+    // Quay camera từ góc đối diện về góc showroom mặc định.
+    InterpolateCameraPos(
+        playerid,
+        2127.20,
+        -1155.10,
+        26.70,
+        DEALERSHIP_CAMERA_X,
+        DEALERSHIP_CAMERA_Y,
+        DEALERSHIP_CAMERA_Z,
+        850,
+        CAMERA_MOVE
+    );
+
+    InterpolateCameraLookAt(
+        playerid,
+        DEALERSHIP_LOOK_X,
+        DEALERSHIP_LOOK_Y,
+        DEALERSHIP_LOOK_Z,
+        DEALERSHIP_LOOK_X,
+        DEALERSHIP_LOOK_Y,
+        DEALERSHIP_LOOK_Z,
+        850,
+        CAMERA_MOVE
+    );
+
+    g_DealershipCameraStage[playerid] = 2;
+    return 1;
+}
